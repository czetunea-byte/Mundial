# Configuración de Firebase para sincronización en tiempo real.
# Copia este archivo a  .env.local  y pega los valores de tu proyecto Firebase.
# (Consola Firebase -> Configuración del proyecto -> Tus apps -> SDK web)
#
# Mientras no llenes esto, la app funciona en "modo local" (solo este navegador).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
